@{
	ViewBag.Title = "Shelter Access Sensor";
}
<div class="app-container">
	<partial name="_SideMenu" />
	<!--Main Area-->
	<div class="main-content">

		<!--Header-->
		<div class="page-header">
			<h2>
				<i class="fas fa-shield-alt"></i>
				Shelter Access
			</h2>
		</div>

		<!--Cards Row-->
		<div class="cards-wrapper">
			<div class="card access-card">
				<div class="card-title">
					Current Sensor Status
					<i class="fas fa-door-open icon-orange"></i>
				</div>
				<div id="current-access-value" class="intrusion-status not-sure-intrusion">
					No Intrusion
				</div>

				<p class="" id="lastUpdate">
					Last Updated: 0000-00-00 00:00:00
				</p>
			</div>
			<div class="card snapshot-card">
				<div class="card-title">
					<svg xmlns="http://www.w3.org/2000/svg" width="25" height="25" fill="currentColor" class="bi bi-camera" viewBox="0 0 16 16">
						<path d="M15 12a1 1 0 0 1-1 1H2a1 1 0 0 1-1-1V6a1 1 0 0 1 1-1h1.172a3 3 0 0 0 2.12-.879l.83-.828A1 1 0 0 1 6.827 3h2.344a1 1 0 0 1 .707.293l.828.828A3 3 0 0 0 12.828 5H14a1 1 0 0 1 1 1zM2 4a2 2 0 0 0-2 2v6a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V6a2 2 0 0 0-2-2h-1.172a2 2 0 0 1-1.414-.586l-.828-.828A2 2 0 0 0 9.172 2H6.828a2 2 0 0 0-1.414.586l-.828.828A2 2 0 0 1 3.172 4z" />
						<path d="M8 11a2.5 2.5 0 1 1 0-5 2.5 2.5 0 0 1 0 5m0 1a3.5 3.5 0 1 0 0-7 3.5 3.5 0 0 0 0 7M3 6.5a.5.5 0 1 1-1 0 .5.5 0 0 1 1 0" />
					</svg>
					Latest Snapshot
				</div>
				<div class="snap-image">
					<img src="/images/shelterAccess.jpg" alt="Last shelter access snapshot" width="780" height="270" loading="lazy" class="rounded"/>
				</div>

				<p class="" id="lastUpdate">
					0000-00-00 00:00:00 
				</p>
			</div>
			<div class="card readings-card">
				<!--<div class="chart-header">-->
				<div class="parent row">
					<div class="col-3">
						<strong class="card-title">
							<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-journal-text" viewBox="0 0 16 16">
								<path d="M5 10.5a.5.5 0 0 1 .5-.5h2a.5.5 0 0 1 0 1h-2a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5m0-2a.5.5 0 0 1 .5-.5h5a.5.5 0 0 1 0 1h-5a.5.5 0 0 1-.5-.5" />
								<path d="M3 0h10a2 2 0 0 1 2 2v12a2 2 0 0 1-2 2H3a2 2 0 0 1-2-2v-1h1v1a1 1 0 0 0 1 1h10a1 1 0 0 0 1-1V2a1 1 0 0 0-1-1H3a1 1 0 0 0-1 1v1H1V2a2 2 0 0 1 2-2" />
								<path d="M1 5v-.5a.5.5 0 0 1 1 0V5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1zm0 3v-.5a.5.5 0 0 1 1 0V8h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1zm0 3v-.5a.5.5 0 0 1 1 0v.5h.5a.5.5 0 0 1 0 1h-2a.5.5 0 0 1 0-1z" />
							</svg>
							Detailed Activity Logs
						</strong>
					</div>
					<div class="col-9 d-inline-flex">
						<div class="quick-filters justify-content-start">
							<button class="download-btn" id="last1HourAccessBtn">Last 1 hour</button>
							<button class="download-btn" id="last24HoursAccessBtn">Last 24 hours</button>
							<button class="download-btn" id="last7DaysAccessBtn">Last 7 days</button>
						</div> 

						<div class="quick-filters justify-content-end"> 
							<span class="p-2">From: </span>
							<input type="date" id="startAccessDate" class="date-input" />
							<span class="p-2">To: </span>
							<input type="date" id="endAccessDate" class="date-input" />

							<button type="button" class="download-btn" id="showHistoryAccessBtn">
								Show History
							</button>
							<button type="button" class="download-btn" onclick="returntoLive()">Return to Live</button>
						</div>
					</div>
					
				</div>
				<!--</div>-->
				<div class="table-responsive">
					<table class="table history-table" id="shelterAccessTable">
						<thead>
							<tr>
								<th>Timestamp (UTC)</th>
								<th>Event</th>
								<th>Sensor</th>
								<th>Status</th>
							</tr>
						</thead>
						<tbody></tbody>
					</table>
				</div>
			</div>
		</div>

	</div>

</div>

@section Scripts {
	<link rel="stylesheet" asp-append-version="true" href="~/css/shelterAccessPage.css" />
	@* <link rel="stylesheet" href="~/css/tempchart.css" /> *@
	<script>
		window.shelterCode ="@ViewBag.ShelterCode";
	</script>

	<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

	@* <script src="/js/tempChart.js"></script> *@

	<script src="/lib/microsoft-signalr/signalr.js"></script>
	<script src="/js/accessShelterSignalR.js"></script>
	<script src="/js/accessShelterHistory.js"></script> 

}
